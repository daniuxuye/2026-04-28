<script>
    // ---------- 卡片1 验证逻辑 ----------
    const answersMap = {
        1: { meaning: "x≠0且x≠5", zero: "x=-5" },
        2: { meaning: "x≠1.5", zero: "x=0" },
        3: { meaning: "x≠3/7", zero: "x=-0.5" }   // -1/2
    };

    function checkCard(cardId) {
        let meaningSelected, zeroSelected, fbDiv;
        if (cardId === 1) {
            meaningSelected = document.querySelector('input[name="meaning1"]:checked');
            zeroSelected = document.querySelector('input[name="zero1"]:checked');
            fbDiv = document.getElementById("fb1");
        } else if (cardId === 2) {
            meaningSelected = document.querySelector('input[name="meaning2"]:checked');
            zeroSelected = document.querySelector('input[name="zero2"]:checked');
            fbDiv = document.getElementById("fb2");
        } else {
            meaningSelected = document.querySelector('input[name="meaning3"]:checked');
            zeroSelected = document.querySelector('input[name="zero3"]:checked');
            fbDiv = document.getElementById("fb3");
        }
        if (!meaningSelected || !zeroSelected) {
            fbDiv.innerHTML = "⚠️ 请分别选中“有意义条件”和“值为0条件”的选项。";
            fbDiv.className = "feedback wrong";
            return;
        }
        const meaningAns = answersMap[cardId].meaning;
        const zeroAns = answersMap[cardId].zero;
        const meaningOk = meaningSelected.value === meaningAns;
        const zeroOk = zeroSelected.value === zeroAns;
        if (meaningOk && zeroOk) {
            fbDiv.innerHTML = "✓ 完全正确！分式有意义条件与值为0条件都正确。";
            fbDiv.className = "feedback correct";
        } else {
            let errMsg = "";
            if (!meaningOk) errMsg += `有意义条件错误（正确应为 ${meaningAns}）。`;
            if (!zeroOk) errMsg += ` 值为0条件错误（正确应为 ${zeroAns}）。`;
            fbDiv.innerHTML = `✗ ${errMsg}`;
            fbDiv.className = "feedback wrong";
        }
    }
    document.querySelectorAll('.check-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const cardVal = btn.getAttribute('data-card');
            checkCard(parseInt(cardVal));
        });
    });

    // 卡片2：表格求值，支持分数输入
    const expectedMap = {
        val_xn3: -0.75,
        val_xn2: -2/3,
        val_xn1: -0.5,
        val_x0: 0,
        val_x2: -2,
        val_x3: -1.5
    };
    function parseFractionOrDecimal(val) {
        val = val.trim();
        if (val.includes('/')) {
            let parts = val.split('/');
            if (parts.length === 2) {
                let num = parseFloat(parts[0]);
                let den = parseFloat(parts[1]);
                if (!isNaN(num) && !isNaN(den) && den !== 0) return num/den;
            }
        }
        let num = parseFloat(val);
        return isNaN(num) ? NaN : num;
    }
    function checkTableValues() {
        let allCorrect = true;
        let errors = [];
        const ids = ['val_xn3', 'val_xn2', 'val_xn1', 'val_x0', 'val_x2', 'val_x3'];
        const labels = ['x=-3', 'x=-2', 'x=-1', 'x=0', 'x=2', 'x=3'];
        ids.forEach((id, idx) => {
            let raw = document.getElementById(id).value;
            if (raw === "") {
                allCorrect = false;
                errors.push(`${labels[idx]} 未填写`);
                return;
            }
            let userNum = parseFractionOrDecimal(raw);
            if (isNaN(userNum)) {
                allCorrect = false;
                errors.push(`${labels[idx]} 输入无效`);
                return;
            }
            let expected = expectedMap[id];
            if (Math.abs(userNum - expected) <= 0.01) return;
            allCorrect = false;
            let expectedShow = (Math.abs(expected) % 1 === 0) ? expected : expected.toFixed(4);
            errors.push(`${labels[idx]} 期望值 ≈ ${expectedShow} ，输入了 ${userNum}`);
        });
        const fbDiv = document.getElementById("tableFeedback");
        if (allCorrect) {
            fbDiv.innerHTML = "✓ 所有分式值计算准确！";
            fbDiv.className = "feedback correct";
        } else {
            fbDiv.innerHTML = "✗ " + errors.join("； ") + "<br>● 参考提示区答案再检查";
            fbDiv.className = "feedback wrong";
        }
    }
    function showTableHint() {
        const fbDiv = document.getElementById("tableFeedback");
        // 以分数样式展示答案
        fbDiv.innerHTML = "参考答案：<br> x=-3 → <span class='fraction'><span class='numerator'>-3</span><span class='denominator'>4</span></span> = -0.75 ； x=-2 → <span class='fraction'><span class='numerator'>-2</span><span class='denominator'>3</span></span> ≈ -0.667 ； x=-1 → <span class='fraction'><span class='numerator'>-1</span><span class='denominator'>2</span></span> = -0.5 ； x=0 → 0 ； x=2 → -2 ； x=3 → <span class='fraction'><span class='numerator'>-3</span><span class='denominator'>2</span></span> = -1.5 。";
        fbDiv.className = "feedback correct";
        setTimeout(() => {
            if (fbDiv.innerHTML.includes("参考答案")) setTimeout(() => fbDiv.innerHTML = "", 4000);
        }, 4000);
    }
    document.getElementById("checkTableBtn").addEventListener("click", checkTableValues);
    document.getElementById("showHintBtn").addEventListener("click", showTableHint);

    // 卡片3 实际表达式验证
    function normalize(str) {
        return str.replace(/\s+/g, '').toLowerCase();
    }
    function isPlantCorrect(expr) {
        let norm = normalize(expr);
        if (/^40\/x$/.test(norm)) return true;
        if (/^1200\/(30\*?x)$/.test(norm)) return true;
        if (/^1200\/30\/x/.test(norm)) return true;
        if (/^\(?1200\)?\/(30x)$/.test(norm)) return true;
        return false;
    }
